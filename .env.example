# ============================================================
# FinWise.th — Environment Variables
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง
# ============================================================

# Google Analytics 4 — ดูได้ที่ analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google AdSense — ดูได้ที่ adsense.google.com
# รูปแบบ: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# AdSense Slot IDs — สร้างแต่ละ slot ใน AdSense console
NEXT_PUBLIC_AD_SLOT_LEADERBOARD=1234567890
NEXT_PUBLIC_AD_SLOT_RECTANGLE=0987654321
NEXT_PUBLIC_AD_SLOT_IN_CONTENT=1122334455
NEXT_PUBLIC_AD_SLOT_SIDEBAR=5544332211

# Google Search Console Verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFY=your-verification-code

# Site URL (สำหรับ sitemap และ canonical URLs)
NEXT_PUBLIC_SITE_URL=https://finwise.th
